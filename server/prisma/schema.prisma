// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  email    String  @unique
  name     String
  provider String? // 'apple' | 'google'
  subject  String? // provider 'sub' — for future account linking
  settings Json? // { autoTrackChapters: Boolean, ... }

  passageTracks PassageTrack[] @relation("passageTracks")
  chapterTracks ChapterTrack[] @relation("chapterTracks")
}

model PassageTrack {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user   User?   @relation("passageTracks", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId String? @db.ObjectId

  passageDate String // 'YYYY-MM-DD'
  passageType String // 'bible' | 'proverbs' | 'psalms' (non-null)
  isRead      Boolean
  trackDate   String // human "when read"
  updatedAt   String // client action-time; sync version (LWW)
  serverAt    String // server receive time (audit)

  @@unique([userId, passageDate, passageType])
}

model ChapterTrack {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user   User?   @relation("chapterTracks", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId String? @db.ObjectId

  book      String // USFM id: GEN, PRO, PSA, ...
  chapter   String
  isRead    Boolean
  trackDate String
  updatedAt String // client action-time; sync version (LWW)
  serverAt  String

  @@unique([userId, book, chapter])
}
